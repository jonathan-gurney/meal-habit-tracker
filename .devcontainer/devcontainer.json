{
  "name": "meal-habit-tracker",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/meal-habit-tracker",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/meal-habit-tracker,type=bind,consistency=cached",
  "postCreateCommand": "npm ci",
  "forwardPorts": [3001, 5173],
  "portsAttributes": {
    "3001": { "label": "Express API" },
    "5173": { "label": "Vite Dev Server" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-js-debug"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "remoteUser": "node"
}
